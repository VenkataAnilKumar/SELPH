# ==============================================================================
# SELPH Backend Environment Configuration
# Copy to .env and fill in with your values
# ==============================================================================

# Application
ENVIRONMENT=development
DEBUG=false
SERVICE_NAME=selph-backend

# API
API_TITLE=SELPH API
API_VERSION=0.1.0
API_V1_STR=/v1

# Database
DATABASE_URL=postgresql://selph:password@localhost:5432/selph

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-here-min-32-chars-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081
ALLOWED_HOSTS=localhost,127.0.0.1

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase@project.iam.gserviceaccount.com

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=selph-media
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Meta (Instagram)
META_APP_ID=...
META_APP_SECRET=...
META_VERIFY_TOKEN=...

# Google (Gmail)
GOOGLE_OAUTH_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_SECRET=...
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/channels/google/callback

# Logging
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Feature Flags
FEATURE_TWIN_BRIEFING=true
FEATURE_VIP_OVERRIDE=true
FEATURE_BATCH_APPROVAL=true
FEATURE_VOICE_CLONE=false
FEATURE_AVATAR_CLONE=false
FEATURE_INSTAGRAM=true
FEATURE_GMAIL=true
FEATURE_TWITTER=false
FEATURE_WHATSAPP=false

# Moderation
MODERATION_THRESHOLD=0.7
STRICT_MODERATION=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=250
